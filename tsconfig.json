{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "App.tsx",
    "index.ts",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "admin-panel",
    "supabase",
    "node_modules"
  ]
}
