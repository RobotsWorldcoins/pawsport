{
  "expo": {
    "name": "Pawsport",
    "slug": "pawsport",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pawsport.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDYCHxaO7AVUL-38TVHuLntdODtZkdz8Ds"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pawsport uses your location to find nearby dog-friendly places.",
        "NSCameraUsageDescription": "Pawsport needs camera access for your dog's profile photo.",
        "NSPhotoLibraryUsageDescription": "Pawsport needs photo library access for your dog's profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.pawsport.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDYCHxaO7AVUL-38TVHuLntdODtZkdz8Ds"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Pawsport uses your location to find nearby dog-friendly places."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pawsport needs photo access for your dog's profile."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.pawsport.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "2.1.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "32815ed6-ae82-44a5-9f23-325ee4c3f690"
      }
    },
    "scheme": "pawsport",
    "owner": "nucca"
  }
}
